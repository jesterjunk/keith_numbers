Notebook[{
Cell["Code to check whether an input is a repfigit (Keith number).", "Text",
 CellChangeTimes->{{3.463513983060961*^9, 3.463514003876996*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", "list_", "]"}], ":=", 
  RowBox[{"Append", "[", 
   RowBox[{
    RowBox[{"Rest", "[", "list", "]"}], ",", 
    RowBox[{"Apply", "[", 
     RowBox[{"Plus", ",", "list"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"knumsums", "[", "list_", "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"val", "=", 
      RowBox[{"FromDigits", "[", "list", "]"}]}], "}"}], ",", 
    RowBox[{"Take", "[", 
     RowBox[{
      RowBox[{"NestWhile", "[", 
       RowBox[{"f", ",", "list", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"Last", "[", "#", "]"}], "<", "val"}], "&"}]}], "]"}], ",", 
      
      RowBox[{"-", "2"}]}], "]"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"knum", "[", "list_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Last", "[", 
    RowBox[{"knumsums", "[", "list", "]"}], "]"}], "===", 
   RowBox[{"FromDigits", "[", "list", "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.454690394830749*^9, 3.454690395389937*^9}, {
  3.463513974368456*^9, 3.4635139775630302`*^9}}],

Cell["\<\
Code to generate the family of repfigit equations for a given number of \
digits. Solutions to any of these equations give Keith numbers of that size. \
A given equation might have zero, one, or more than one solution over the \
integers.\
\>", "Text",
 CellChangeTimes->{{3.463513983060961*^9, 3.463514050181261*^9}, {
  3.463514477833188*^9, 3.463514532441736*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"keithEquations", "[", 
   RowBox[{"len_Integer", "/;", 
    RowBox[{"len", ">", "0"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"matrow", ",", "n", ",", "list", ",", "res", ",", "vecs"}], 
     "}"}], ",", 
    RowBox[{
     RowBox[{"res", "=", 
      RowBox[{"list", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"matrow", "[", "j", "]"}], "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"k", ",", 
            RowBox[{"j", "+", "1"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "len"}], "}"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", 
         RowBox[{"len", "-", "1"}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"matrow", "[", "len", "]"}], "=", 
      RowBox[{"Table", "[", 
       RowBox[{"1", ",", 
        RowBox[{"{", "len", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"n", "=", "len"}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"9", "*", 
         RowBox[{"Apply", "[", 
          RowBox[{"Plus", ",", 
           RowBox[{"matrow", "[", "n", "]"}]}], "]"}]}], "<", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"len", "-", "1"}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{"n", "++"}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"matrow", "[", "n", "]"}], "=", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"matrow", "[", "k", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", 
             RowBox[{"n", "-", "len"}], ",", 
             RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], ";"}]}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"First", "[", 
         RowBox[{"matrow", "[", "n", "]"}], "]"}], "\[LessEqual]", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"len", "-", "1"}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{"res", "=", 
         RowBox[{"list", "[", 
          RowBox[{"res", ",", 
           RowBox[{"matrow", "[", "n", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"n", "++"}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"matrow", "[", "n", "]"}], "=", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"matrow", "[", "k", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", 
             RowBox[{"n", "-", "len"}], ",", 
             RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], ";"}]}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"vecs", "=", 
      RowBox[{"Apply", "[", 
       RowBox[{"List", ",", 
        RowBox[{"Flatten", "[", 
         RowBox[{"res", ",", "Infinity", ",", "list"}], "]"}]}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"#", "-", 
          RowBox[{"10", "^", 
           RowBox[{"Range", "[", 
            RowBox[{
             RowBox[{"len", "-", "1"}], ",", "0", ",", 
             RowBox[{"-", "1"}]}], "]"}]}]}], ")"}], "&"}], ",", "vecs"}], 
      "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.454672893725027*^9, 3.454672902316613*^9}, 
   3.463514057141473*^9}],

Cell["\<\
Code to solve a given repfigit equation. It gives out information as it runs.\
\
\>", "Text",
 CellChangeTimes->{{3.463513983060961*^9, 3.463514074533435*^9}, {
  3.4635144467132387`*^9, 3.4635144616889887`*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SetSystemOptions", "[", 
    RowBox[{"\"\<LatticeReduceOptions\>\"", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<LatticeReduceRatioParameter\>\"", "\[Rule]", ".999"}], 
      "}"}]}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"integerNullSpace", "[", 
   RowBox[{"vec", ":", 
    RowBox[{"{", 
     RowBox[{"_Integer", ".."}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mat", ",", "hnf"}], "}"}], ",", 
    RowBox[{
     RowBox[{"mat", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", "vec", "}"}], ",", 
         RowBox[{"IdentityMatrix", "[", 
          RowBox[{"Length", "[", "vec", "]"}], "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"hnf", "=", 
      RowBox[{"Last", "[", 
       RowBox[{"HermiteDecomposition", "[", "mat", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"LatticeReduce", "[", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Drop", "[", 
          RowBox[{"#", ",", "1"}], "]"}], "&"}], ",", 
        RowBox[{"Drop", "[", 
         RowBox[{"hnf", ",", "1"}], "]"}]}], "]"}], "]"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.454672893725027*^9, 3.454672902316613*^9}, {
  3.463514057141473*^9, 3.463514059535079*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetOptions", "[", 
   RowBox[{"LinearProgramming", ",", 
    RowBox[{"Method", "\[Rule]", "\"\<CLP\>\""}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"keithSolutions", "[", "onulls_", "]"}], ":=", 
  RowBox[{"Catch", "[", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"nulls", ",", 
       RowBox[{"len", "=", 
        RowBox[{"Length", "[", "onulls", "]"}]}], ",", 
       RowBox[{"len2", "=", 
        RowBox[{"Length", "[", 
         RowBox[{"onulls", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ",", "order", ",", "stack",
        ",", "soln", ",", 
       RowBox[{"solns", "=", 
        RowBox[{"{", "}"}]}], ",", "badvar", ",", "val", ",", 
       RowBox[{"counter", "=", "0"}], ",", "vval", ",", 
       RowBox[{"eps", "=", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "8"}], ")"}]}]}], ",", "rndvar", ",", "bnds1", ",", 
       "bnds2", ",", "obnds", ",", "mat", ",", "vec", ",", "b2b", ",", 
       "gcds"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"nulls", "=", 
       RowBox[{"Reverse", "[", 
        RowBox[{"onulls", "[", 
         RowBox[{"[", 
          RowBox[{"Ordering", "[", 
           RowBox[{"Map", "[", 
            RowBox[{"Norm", ",", 
             RowBox[{"N", "[", "onulls", "]"}]}], "]"}], "]"}], "]"}], "]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"nulls", "=", 
       RowBox[{"Transpose", "[", "nulls", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"gcds", "=", 
       RowBox[{"Apply", "[", 
        RowBox[{"GCD", ",", "nulls", ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"nulls", "=", 
       RowBox[{"nulls", "/", "gcds"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"mat", "=", 
       RowBox[{"N", "[", 
        RowBox[{"Join", "[", 
         RowBox[{"nulls", ",", 
          RowBox[{"-", "nulls"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"bnds1", "=", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0", ",", "len2"}], "]"}], ",", 
         RowBox[{"Ceiling", "[", 
          RowBox[{
           RowBox[{"ConstantArray", "[", 
            RowBox[{
             RowBox[{"-", "9"}], ",", "len2"}], "]"}], "/", "gcds"}], "]"}]}],
         "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"bnds1", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "=", "1"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"bnds2", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
         RowBox[{"{", "len", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"bnds2", "=!=", "obnds"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"obnds", "=", "bnds2"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{"UnitVector", "[", 
              RowBox[{"len", ",", "j"}], "]"}]}], ";", "\[IndentingNewLine]", 
            
            RowBox[{"Quiet", "[", 
             RowBox[{"soln", "=", 
              RowBox[{"LinearProgramming", "[", 
               RowBox[{"vec", ",", "mat", ",", "bnds1", ",", "bnds2"}], 
               "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Head", "[", "soln", "]"}], "===", 
                "LinearProgramming"}], "||", 
               RowBox[{"!", 
                RowBox[{"FreeQ", "[", 
                 RowBox[{"soln", ",", "Indeterminate"}], "]"}]}]}], ",", 
              RowBox[{"Throw", "[", 
               RowBox[{"{", 
                RowBox[{"0", ",", 
                 RowBox[{"{", "}"}]}], "}"}], "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"val", "=", 
             RowBox[{"vec", ".", "soln"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"bnds2", "[", 
              RowBox[{"[", 
               RowBox[{"j", ",", "1"}], "]"}], "]"}], "=", 
             RowBox[{"Ceiling", "[", 
              RowBox[{"val", "-", "eps"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Quiet", "[", 
             RowBox[{"soln", "=", 
              RowBox[{"LinearProgramming", "[", 
               RowBox[{
                RowBox[{"-", "vec"}], ",", "mat", ",", "bnds1", ",", 
                "bnds2"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Head", "[", "soln", "]"}], "===", 
                "LinearProgramming"}], "||", 
               RowBox[{"!", 
                RowBox[{"FreeQ", "[", 
                 RowBox[{"soln", ",", "Indeterminate"}], "]"}]}]}], ",", 
              RowBox[{"Throw", "[", 
               RowBox[{"{", 
                RowBox[{"0", ",", 
                 RowBox[{"{", "}"}]}], "}"}], "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"val", "=", 
             RowBox[{"vec", ".", "soln"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"bnds2", "[", 
              RowBox[{"[", 
               RowBox[{"j", ",", "2"}], "]"}], "]"}], "=", 
             RowBox[{"Ceiling", "[", 
              RowBox[{"val", "-", "eps"}], "]"}]}], ";"}], 
           "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "len"}], "}"}]}], "]"}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"order", "=", 
       RowBox[{"Ordering", "[", 
        RowBox[{
         RowBox[{"bnds2", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "2"}], "]"}], "]"}], "-", 
         RowBox[{"bnds2", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"bnds2", "=", 
       RowBox[{"bnds2", "[", 
        RowBox[{"[", "order", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"nulls", "=", 
       RowBox[{"nulls", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "order"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mat", "=", 
       RowBox[{"N", "[", 
        RowBox[{"Join", "[", 
         RowBox[{"nulls", ",", 
          RowBox[{"-", "nulls"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"stack", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"bnds1", ",", "bnds2"}], "}"}], ",", 
         RowBox[{"{", "}"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"stack", "=!=", 
         RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"counter", "++"}], ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"bnds1", ",", "bnds2"}], "}"}], "=", 
          RowBox[{"stack", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"stack", "=", 
          RowBox[{"stack", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"rndvar", "=", 
          RowBox[{
           RowBox[{"RandomInteger", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", "len"}], "}"}], "]"}], "*", 
           RowBox[{"RandomChoice", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"vec", "=", 
          RowBox[{"UnitVector", "[", 
           RowBox[{"len", ",", 
            RowBox[{"Abs", "[", "rndvar", "]"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Quiet", "[", 
          RowBox[{"soln", "=", 
           RowBox[{"LinearProgramming", "[", 
            RowBox[{
             RowBox[{"vec", "*", 
              RowBox[{"Sign", "[", "rndvar", "]"}]}], ",", "mat", ",", 
             "bnds1", ",", "bnds2"}], "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Head", "[", "soln", "]"}], "===", "LinearProgramming"}], 
           ",", 
           RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"!", 
            RowBox[{"FreeQ", "[", 
             RowBox[{"soln", ",", "Indeterminate"}], "]"}]}], ",", 
           RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"vval", "=", 
          RowBox[{"Ceiling", "[", 
           RowBox[{
            RowBox[{"soln", ".", "vec"}], "-", "eps"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"bnds2", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Abs", "[", "rndvar", "]"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"1", "-", 
                 RowBox[{"Sign", "[", "rndvar", "]"}]}], ")"}], "/", "2"}], 
              "+", "1"}]}], "]"}], "]"}], "=", "vval"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"badvar", "=", 
          RowBox[{"Position", "[", 
           RowBox[{"soln", ",", 
            RowBox[{"(", 
             RowBox[{"a_", "/;", 
              RowBox[{
               RowBox[{"Chop", "[", 
                RowBox[{"a", "-", 
                 RowBox[{"Round", "[", "a", "]"}]}], "]"}], "=!=", "0"}]}], 
             ")"}], ",", 
            RowBox[{"{", "1", "}"}], ",", "1", ",", 
            RowBox[{"Heads", "\[Rule]", "False"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"badvar", "===", 
            RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"soln", "=", 
             RowBox[{"Round", "[", "soln", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"solns", "=", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Flatten", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"gcds", "*", "nulls"}], ")"}], ".", "soln"}], "]"}],
                ",", "solns"}], "}"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{"\"\<sol \>\"", ",", 
              RowBox[{"Flatten", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"gcds", "*", "nulls"}], ")"}], ".", "soln"}], 
               "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"Do", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"b2b", "=", "bnds2"}], ";", "\[IndentingNewLine]", 
               RowBox[{"Do", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"b2b", "[", 
                   RowBox[{"[", "k", "]"}], "]"}], "=", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"soln", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], ",", 
                    RowBox[{"soln", "[", 
                    RowBox[{"[", "k", "]"}], "]"}]}], "}"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"k", ",", 
                   RowBox[{"j", "-", "1"}]}], "}"}]}], "]"}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"b2b", "[", 
                 RowBox[{"[", "j", "]"}], "]"}], "=", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"bnds2", "[", 
                   RowBox[{"[", 
                    RowBox[{"j", ",", "1"}], "]"}], "]"}], ",", 
                  RowBox[{
                   RowBox[{"soln", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "-", "1"}]}], "}"}]}], 
               ";", "\[IndentingNewLine]", 
               RowBox[{"stack", "=", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"bnds1", ",", "b2b"}], "}"}], ",", "stack"}], 
                 "}"}]}], ";", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"b2b", "[", 
                 RowBox[{"[", "j", "]"}], "]"}], "=", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"soln", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "+", "1"}], ",", 
                  RowBox[{"bnds2", "[", 
                   RowBox[{"[", 
                    RowBox[{"j", ",", "2"}], "]"}], "]"}]}], "}"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"stack", "=", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"bnds1", ",", "b2b"}], "}"}], ",", "stack"}], 
                 "}"}]}], ";"}], "\[IndentingNewLine]", ",", 
              RowBox[{"{", 
               RowBox[{"j", ",", 
                RowBox[{"Length", "[", "soln", "]"}]}], "}"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Continue", "[", "]"}]}]}], "\[IndentingNewLine]", "]"}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{"badvar", "=", 
          RowBox[{"badvar", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"val", "=", 
          RowBox[{"soln", "[", 
           RowBox[{"[", "badvar", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         
         RowBox[{"b2b", "=", "bnds2"}], ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"b2b", "[", 
           RowBox[{"[", "badvar", "]"}], "]"}], "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"bnds2", "[", 
             RowBox[{"[", 
              RowBox[{"badvar", ",", "1"}], "]"}], "]"}], ",", 
