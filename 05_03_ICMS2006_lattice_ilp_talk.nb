Cell[CellGroupData[{

Cell["Simple example finding a Keith number", "Section"],

Cell["\<\
The idea: For each null vector we create an integer\[Hyphen]valued variable. \
Allow arbitrary linear combinations of these vectors subject to the \
constraints that all resulting components be nonnegative, and the first be \
positive. This is simply a constraint satisfaction problem. We use a handy \
optimizer and we are off to the races.\
\>", "Text",
 CellChangeTimes->{3.36544125197024*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"keithSolution", "[", 
   RowBox[{"nulls_", ",", 
    RowBox[{"iters_:", "Automatic"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"len", "=", 
       RowBox[{"Length", "[", "nulls", "]"}]}], ",", "vars", ",", "x", ",", 
      "vec", ",", "constraints", ",", "program", ",", "min", ",", "vals"}], 
     "}"}], ",", 
    RowBox[{
     RowBox[{"vars", "=", 
      RowBox[{"Array", "[", 
       RowBox[{"x", ",", "len"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"vec", "=", 
      RowBox[{"vars", ".", "nulls"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"constraints", "=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Element", "[", 
           RowBox[{"vars", ",", "Integers"}], "]"}], ",", 
          RowBox[{"1", "\[LessEqual]", 
           RowBox[{"First", "[", "vec", "]"}], "\[LessEqual]", "9"}]}], "}"}],
         ",", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"0", "\[LessEqual]", "#", "\[LessEqual]", "9"}], "&"}], 
          ",", 
          RowBox[{"Rest", "[", "vec", "]"}]}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"program", "=", 
      RowBox[{"{", 
       RowBox[{"1", ",", "constraints"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"min", ",", "vals"}], "}"}], "=", 
      RowBox[{"NMinimize", "[", 
       RowBox[{"program", ",", "vars", ",", 
        RowBox[{"MaxIterations", "\[Rule]", "iters"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"vec", "/.", "vals"}]}]}], "]"}]}]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"keithSolution", "[", 
  RowBox[{"nulls", "[", 
   RowBox[{"6", ",", "2"}], "]"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "4", ",", "7", ",", "6", ",", "4", ",", "0"}], 
  "}"}]], "Output"]
}, Open  ]],

Cell[TextData[{
 "One can check that ",
 Cell[BoxData[
  FormBox["147640", TraditionalForm]]],
 " is in fact a repfigit."
}], "Text",
 CellChangeTimes->{{3.36544110958797*^9, 3.36544110973116*^9}}],

Cell["\<\
This method of finding such numbers using a black-box optimizer is a bit \
lame. But it illustrates the basic idea, which was to form a constraint \
satisfaction problem using integer combinations of a lattice\[Hyphen]reduced \
set of generators. So what remains is to do this in a systematic and \
efficient, manner.\
\>", "Text",
 CellChangeTimes->{{3.36544114220498*^9, 3.36544124015945*^9}, {
  3.3654429422954*^9, 3.3654429558044*^9}}]
}, Open  ]]
}, Open  ]],

