Cell[CellGroupData[{

Cell["Frobenius instances can be tricky", "Section",
 CellChangeTimes->{{3.36546626715404*^9, 3.36546626814918*^9}}],

Cell[TextData[{
 "The picture may give some idea. The \"bad\" directions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["b", "1"], ",", 
     SubscriptBox["b", "2"]}], "}"}], TraditionalForm]]],
 " can cause us to wander in the triangle (imagine it to be longer but not \
wider), whereas we can quickly learn that not many integer multiples of the \
good direction ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "2"], TraditionalForm]]],
 " will stay inside it."
}], "Text"],

