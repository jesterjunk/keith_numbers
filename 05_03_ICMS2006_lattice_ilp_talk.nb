Cell[CellGroupData[{

Cell["Big Keith numbers", "Section"],

Cell["\<\
First we will see the code. Actually this is quite unlikely, because I have \
the font size reduced, but I want to show that it can fit comfortably on two \
pages or less.\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"keithSolutions", "[", "onulls_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"nulls", ",", "vars", ",", "x", ",", 
      RowBox[{"len", "=", 
       RowBox[{"Length", "[", "onulls", "]"}]}], ",", "vecs", ",", 
      "constraints", ",", "program", ",", "stack", ",", "soln", ",", 
      RowBox[{"solns", "=", 
       RowBox[{"{", "}"}]}], ",", "badvar", ",", "varvals", ",", "val", ",", 
      RowBox[{"counter", "=", "1"}], ",", "var", ",", "extra", ",", "maxs", 
      ",", "mins", ",", 
      RowBox[{"ctmp", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"bad", "=", "False"}], ",", "vnum", ",", "vval", ",", 
      RowBox[{"eps", "=", 
       RowBox[{"10", "^", 
        RowBox[{"(", 
         RowBox[{"-", "5"}], ")"}]}]}], ",", "rndvar"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"nulls", "=", 
      RowBox[{"Reverse", "[", 
       RowBox[{"onulls", "[", 
        RowBox[{"[", 
         RowBox[{"Ordering", "[", 
          RowBox[{"Map", "[", 
           RowBox[{"Norm", ",", 
            RowBox[{"N", "[", "onulls", "]"}]}], "]"}], "]"}], "]"}], "]"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"vars", "=", 
      RowBox[{"Array", "[", 
       RowBox[{"x", ",", "len"}], "]"}]}], ";", 
     RowBox[{"vecs", "=", 
      RowBox[{"vars", ".", "nulls"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"constraints", "=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", "\[LessEqual]", 
          RowBox[{"First", "[", "vecs", "]"}], "\[LessEqual]", "9"}], "}"}], 
        ",", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"0", "\[LessEqual]", "#", "\[LessEqual]", "9"}], "&"}], 
          ",", 
          RowBox[{"Rest", "[", "vecs", "]"}]}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"mins", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Internal`DeactivateMessages", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"val", "=", 
               RowBox[{"NMinimize", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"vars", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], ",", 
                   RowBox[{"Join", "[", 
                    RowBox[{"constraints", ",", "ctmp"}], "]"}]}], "}"}], ",",
                  "vars"}], "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"Head", "[", "val", "]"}], "===", "NMinimize"}], "||", 
                 RowBox[{"!", 
                  RowBox[{"FreeQ", "[", 
                   RowBox[{"val", ",", "Indeterminate"}], "]"}]}]}], ",", 
                RowBox[{
                 RowBox[{"bad", "=", "True"}], ";", 
                 RowBox[{"Break", "[", "]"}]}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"val", "=", 
               RowBox[{"First", "[", "val", "]"}]}]}], ",", 
             RowBox[{"NMinimize", "::", "\"\<nsol\>\""}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "len"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"maxs", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Internal`DeactivateMessages", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"val", "=", 
               RowBox[{"NMaximize", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"vars", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], ",", 
                   RowBox[{"Join", "[", 
                    RowBox[{"constraints", ",", "ctmp"}], "]"}]}], "}"}], ",",
                  "vars"}], "]"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"Head", "[", "val", "]"}], "===", "NMaximize"}], "||", 
                 RowBox[{"!", 
                  RowBox[{"FreeQ", "[", 
                   RowBox[{"val", ",", "Indeterminate"}], "]"}]}]}], ",", 
                RowBox[{
                 RowBox[{"bad", "=", "True"}], ";", 
                 RowBox[{"Break", "[", "]"}]}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"val", "=", 
               RowBox[{"First", "[", "val", "]"}]}]}], ",", 
             RowBox[{"NMaximize", "::", "\"\<nsol\>\""}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "len"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ctmp", "=", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Thread", "[", 
            RowBox[{"LessEqual", "[", 
             RowBox[{"vars", ",", 
              RowBox[{"Floor", "[", 
               RowBox[{"maxs", "+", "eps"}], "]"}]}], "]"}], "]"}], ",", 
           RowBox[{"Thread", "[", 
            RowBox[{"GreaterEqual", "[", 
             RowBox[{"vars", ",", 
              RowBox[{"Ceiling", "[", 
               RowBox[{"mins", "-", "eps"}], "]"}]}], "]"}], "]"}]}], "]"}]}],
         ";"}], "\[IndentingNewLine]", ",", 
       RowBox[{"{", "4", "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{"bad", ",", 
       RowBox[{"Return", "[", 
        RowBox[{"{", 
         RowBox[{"counter", ",", 
          RowBox[{"{", "}"}]}], "}"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"constraints", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"constraints", ",", "ctmp"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"program", "=", "constraints"}], ";", 
     RowBox[{"stack", "=", 
      RowBox[{"{", 
       RowBox[{"program", ",", 
        RowBox[{"{", "}"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"stack", "=!=", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{
        RowBox[{"counter", "++"}], ";", 
        RowBox[{"program", "=", 
         RowBox[{"stack", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", 
        RowBox[{"stack", "=", 
         RowBox[{"stack", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"rndvar", "=", 
         RowBox[{"vars", "[", 
          RowBox[{"[", 
           RowBox[{"Random", "[", 
            RowBox[{"Integer", ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "len"}], "}"}]}], "]"}], "]"}], "]"}]}], ";", 
        
        RowBox[{"program", "=", 
         RowBox[{"{", 
          RowBox[{"rndvar", ",", "program"}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Internal`DeactivateMessages", "[", 
         RowBox[{
          RowBox[{"vals", "=", 
           RowBox[{"NMinimize", "[", 
            RowBox[{"program", ",", "vars"}], "]"}]}], ",", 
          RowBox[{"NMinimize", "::", "\"\<nsol\>\""}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Head", "[", "vals", "]"}], "\[Equal]", "NMinimize"}], ",", 
          RowBox[{"Continue", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"vval", "=", 
         RowBox[{"Ceiling", "[", 
          RowBox[{
           RowBox[{"First", "[", "vals", "]"}], "-", "eps"}], "]"}]}], ";", 
        RowBox[{"vals", "=", 
         RowBox[{"Chop", "[", 
          RowBox[{"vals", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";", 
        RowBox[{"soln", "=", 
         RowBox[{"Chop", "[", 
          RowBox[{"vecs", "/.", "vals"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"FreeQ", "[", 
            RowBox[{"soln", ",", "Indeterminate"}], "]"}]}], ",", 
          RowBox[{"Continue", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"constraints", "=", 
         RowBox[{"program", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ";", 
        RowBox[{"varvals", "=", 
         RowBox[{"vars", "/.", "vals"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"badvar", "=", 
         RowBox[{"Position", "[", 
          RowBox[{"varvals", ",", 
           RowBox[{"(", 
            RowBox[{"a_", "/;", 
             RowBox[{
              RowBox[{"Chop", "[", 
               RowBox[{"a", "-", 
                RowBox[{"Round", "[", "a", "]"}]}], "]"}], "=!=", "0"}]}], 
            ")"}], ",", 
           RowBox[{"{", "1", "}"}], ",", "1", ",", 
           RowBox[{"Heads", "\[Rule]", "False"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"badvar", "\[Equal]", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{
           RowBox[{"soln", "=", 
            RowBox[{"Round", "[", "soln", "]"}]}], ";", 
           RowBox[{"solns", "=", 
            RowBox[{"{", 
             RowBox[{"soln", ",", "solns"}], "}"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"extra", "=", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"vecs", "[", 
                   RowBox[{"[", "k", "]"}], "]"}], "\[Equal]", 
                  RowBox[{"soln", "[", 
                   RowBox[{"[", "k", "]"}], "]"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"k", ",", 
                   RowBox[{"j", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"stack", "=", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Join", "[", 
                  RowBox[{"constraints", ",", 
                   RowBox[{"Append", "[", 
                    RowBox[{"extra", ",", 
                    RowBox[{
                    RowBox[{"vecs", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "\[LessEqual]", 
                    RowBox[{
                    RowBox[{"soln", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "-", "1"}]}]}], "]"}]}], 
                  "]"}], ",", "stack"}], "}"}]}], ";", "\[IndentingNewLine]", 
              
              RowBox[{"stack", "=", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Join", "[", 
                  RowBox[{"constraints", ",", 
                   RowBox[{"Append", "[", 
                    RowBox[{"extra", ",", 
                    RowBox[{
                    RowBox[{"vecs", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "\[GreaterEqual]", 
                    RowBox[{
                    RowBox[{"soln", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "+", "1"}]}]}], "]"}]}], 
                  "]"}], ",", "stack"}], "}"}]}], ";"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", 
               RowBox[{"Length", "[", "soln", "]"}]}], "}"}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Continue", "[", "]"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"badvar", "=", 
         RowBox[{"badvar", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", 
        RowBox[{"var", "=", 
         RowBox[{"vars", "[", 
          RowBox[{"[", "badvar", "]"}], "]"}]}], ";", 
        RowBox[{"val", "=", 
         RowBox[{"var", "/.", "vals"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"stack", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Join", "[", 
            RowBox[{"constraints", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"rndvar", "\[GreaterEqual]", "vval"}], ",", 
               RowBox[{"var", "\[LessEqual]", 
                RowBox[{"Floor", "[", "val", "]"}]}]}], "}"}]}], "]"}], ",", 
           "stack"}], "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"stack", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Join", "[", 
            RowBox[{"constraints", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"rndvar", "\[GreaterEqual]", "vval"}], ",", 
               RowBox[{"var", "\[GreaterEqual]", 
                RowBox[{"Ceiling", "[", "val", "]"}]}]}], "}"}]}], "]"}], ",",
            "stack"}], "}"}]}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"counter", ",", 
       RowBox[{"Partition", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", "solns", "]"}], ",", 
         RowBox[{"Length", "[", 
          RowBox[{"First", "[", "nulls", "]"}], "]"}]}], "]"}]}], "}"}]}]}], 
   "]"}]}]], "Input",
 FontSize->8]
}, Open  ]]
}, Open  ]],

