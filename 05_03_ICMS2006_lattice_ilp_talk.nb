Cell[CellGroupData[{

Cell["Frobenius instances", "Section",
 CellChangeTimes->{{3.36544387325094*^9, 3.36544387339277*^9}}],

Cell["We return to the Frobenius problems.", "Text",
 CellChangeTimes->{{3.36544239056496*^9, 3.36544240406726*^9}}],

Cell[CellGroupData[{

Cell["Solving Frobenius instances", "Subsubsection"],

Cell["\<\
One quickly sees that this is the same sort of linear diophantine problem as \
was encountered in finding Keith numbers. So we would like to believe we can \
attack it similarly and have similar success. But wait...\
\>", "Text"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

