Cell[CellGroupData[{

Cell["Summary", "Section"],

Cell["\<\
Lattice methods are, as ever, quite useful for solving linear diophantine \
problems. This is true even in the presence of possibly unpleasant \
constraints.\
\>", "Text",
 CellDingbat->"\[FilledSmallCircle]"]
}, Open  ]]
}, Open  ]],

