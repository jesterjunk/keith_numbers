     ButtonFunction:>FrontEndExecute[{
        FrontEndToken[
         FrontEnd`SelectedNotebook[], "ScrollPageNext"]}],
     ButtonNote->"Next Slide",
     Evaluator->Automatic], 
    ButtonBox[
     StyleBox["\<\"\[LastPage]\"\>", "SR"],
     BaseStyle->"SlideHyperlink",
