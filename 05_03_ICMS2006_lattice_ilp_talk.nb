Cell[CellGroupData[{

Cell["Simple example finding a Keith number", "Section"],

Cell["Quick example:", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"k6", "=", 
   RowBox[{"keithEquations", "[", "6", "]"}]}], ";"}]], "Input"],

Cell[TextData[{
 "We'll work with the second possible equation for ",
 Cell[BoxData[
  FormBox["6", TraditionalForm]]],
 " digit Keith numbers."
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"k6", "[", 
  RowBox[{"[", "2", "]"}], "]"}]], "Input"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "96160"}], ",", 
   RowBox[{"-", "4224"}], ",", "5752", ",", "7144", ",", "7482", ",", 
   "7616"}], "}"}]], "Output"]
}, Open  ]],

Cell["The equation this represents is:", "Text",
 CellChangeTimes->{{3.36543600228186*^9, 3.36543601206762*^9}}],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"-", "96160"}], " ", 
     SubscriptBox["d", "0"]}], " ", "-", " ", 
    RowBox[{"4224", " ", 
     SubscriptBox["d", "1"]}], " ", "+", " ", 
    RowBox[{"5752", " ", 
     SubscriptBox["d", "2"]}], " ", "+", "    ", 
    RowBox[{"7144", " ", 
     SubscriptBox["d", "3"]}], "+", " ", 
    RowBox[{"7482", " ", 
     SubscriptBox["d", "4"]}], "+", " ", 
    RowBox[{"7616", " ", 
     SubscriptBox["d", "5"]}]}], " ", "==", " ", "0"}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.36543605164024*^9, 3.36543613318209*^9}}]
}, Open  ]]
}, Open  ]],

